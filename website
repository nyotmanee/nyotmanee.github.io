<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content="Natasha Yotmanee - International Relations | Data Science | Indo-Pacific" />
  <title>Natasha Yotmanee</title>

  <style>
    :root{
      --bg: #ffffff;
      --bg2: #f6fbfa;

      --panel: #ffffff;

      --text: #0f172a;
      --muted:#475569;
      --muted2:#64748b;
      --border:#e2e8f0;

      --shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
      --shadow2: 0 14px 30px rgba(15, 23, 42, 0.10);
      --radius: 18px;
      --max: 1040px;

      --accent: #0ea5a6;
      --accent2:#2563eb;
      --purple: #6366f1;

      --link: #0b6b6b;
      --focus: rgba(37,99,235,0.18);

      --btnBg: rgba(14,165,166,0.10);
      --btnBd: rgba(14,165,166,0.28);
      --btnTx: #064e4e;

      --fxBg: rgba(99,102,241,0.12);
      --fxBd: rgba(99,102,241,0.34);
      --fxTx: #3730a3;

      --skillBg: rgba(37,99,235,0.10);
      --skillBd: rgba(37,99,235,0.26);
      --skillTx: #1e3a8a;

      --lovePurpleBg: rgba(99,102,241,0.08);
      --lovePurpleBd: rgba(99,102,241,0.22);

      --loveGreenBg: rgba(14,165,166,0.08);
      --loveGreenBd: rgba(14,165,166,0.22);

      --loveBlueBg: rgba(37,99,235,0.06);
      --loveBlueBd: rgba(37,99,235,0.18);

      /* Open Post button alternating colors — matched to "Some Things I Love" cards */
      /* Purple  (Food 🍲) */
      --opBtn1Bg: rgba(99,102,241,0.12);
      --opBtn1Bd: rgba(99,102,241,0.30);
      --opBtn1Tx: #3730a3;
      /* Blue  (Travel 🌎) */
      --opBtn2Bg: rgba(37,99,235,0.10);
      --opBtn2Bd: rgba(37,99,235,0.28);
      --opBtn2Tx: #1e3a8a;
      /* Green  (Books 📚) */
      --opBtn3Bg: rgba(14,165,166,0.10);
      --opBtn3Bd: rgba(14,165,166,0.28);
      --opBtn3Tx: #064e4e;
      /* Teal  (Bucket List) */
      --opBtn4Bg: rgba(14,165,166,0.06);
      --opBtn4Bd: rgba(14,165,166,0.20);
      --opBtn4Tx: #065f5f;

      --researchCardBg: rgba(99,102,241,0.06);
      --researchCardBd: rgba(99,102,241,0.18);

      --pubCardBg: rgba(14,165,166,0.06);
      --pubCardBd: rgba(14,165,166,0.18);

      --activeTabBg: rgba(67, 56, 202, 0.14);
      --activeTabBd: rgba(67, 56, 202, 0.30);
      --activeTabTx: #312e81;

      --rcBtnBg: rgba(99,102,241,0.12);
      --rcBtnBd: rgba(99,102,241,0.34);
      --rcBtnTx: #3730a3;

      --contactGreenBg: rgba(14,165,166,0.10);
      --contactGreenBd: rgba(14,165,166,0.26);
      --contactGreenTx: #064e4e;

      --contactBlueBg: rgba(37,99,235,0.10);
      --contactBlueBd: rgba(37,99,235,0.24);
      --contactBlueTx: #1e3a8a;
    }

    * { box-sizing: border-box; }
    html, body { height: 100%; }
    html {
      background:
        radial-gradient(ellipse 200% 100% at 0% 0%,   rgba(14,165,166,0.07),  transparent 65%),
        radial-gradient(ellipse 180% 90%  at 100% 0%,  rgba(37,99,235,0.05),   transparent 65%),
        radial-gradient(ellipse 200% 80%  at 50% 50%,  rgba(99,102,241,0.04),  transparent 65%),
        radial-gradient(ellipse 200% 80%  at 0% 100%,  rgba(14,165,166,0.05),  transparent 65%),
        radial-gradient(ellipse 180% 80%  at 100% 100%,rgba(37,99,235,0.04),   transparent 65%),
        #ffffff;
      min-height: 100%;
    }
    body{
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      color: var(--text);
      background: transparent;
      line-height: 1.55;
    }

    a{ color: var(--link); text-decoration: none; }
    a:hover{ text-decoration: underline; }

    .wrap{
      width: 100%;
      max-width: var(--max);
      margin: 0 auto;
      padding: 18px 18px 72px;
      position: relative;
      z-index: 0;
    }

    .topbar{
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255,255,255,0.86);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 8px;
      margin: 0;
    }

    .hamburger span {
      width: 24px;
      height: 2px;
      background: var(--text);
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    .hamburger.active span:nth-child(1) {
      transform: rotate(45deg) translate(8px, 8px);
    }

    .hamburger.active span:nth-child(2) {
      opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -7px);
    }

    .navWrapper {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
      transition: max-height 0.3s ease;
    }

    @media (max-width: 999px) {
      .nav {
        position: absolute;
        top: 70px;
        left: 0;
        right: 0;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        flex-direction: column;
        padding: 12px;
        border-bottom: 1px solid var(--border);
        max-height: 0;
        overflow: hidden;
        justify-content: flex-start;
        align-items: stretch;
        width: 100%;
        gap: 4px;
      }

      .nav.visible {
        max-height: 500px;
      }

      .nav .pill {
        width: 100%;
      }
    }

    @media (min-width: 1000px) {
      .nav {
        position: static;
        background: transparent;
        backdrop-filter: none;
        flex-direction: row;
        padding: 0;
        border-bottom: none;
        max-height: 100%;
        overflow: visible;
        justify-content: flex-end;
        align-items: center;
        width: auto;
        gap: 8px;
      }

      .nav .pill {
        width: auto;
      }

      .nav:not(.visible) {
        max-height: 0;
        overflow: hidden;
      }

      .nav.visible {
        max-height: 100%;
      }
    }

    /* Offset anchor scroll targets so the sticky header never covers them */
    [id]{
      scroll-margin-top: 80px;
    }
    .topbarInner{
      max-width: var(--max);
      margin: 0 auto;
      padding: 12px 18px;
      display: flex;
      gap: 12px;
      align-items: center;
      justify-content: space-between;
    }
    .brand{
      display: flex;
      gap: 12px;
      align-items: center;
      min-width: 240px;
      flex: 1;
    }
    .avatar{
      width: 38px; height: 38px;
      border-radius: 14px;
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: var(--shadow);
      background: linear-gradient(135deg, rgba(14,165,166,0.18), rgba(37,99,235,0.18));
      flex: 0 0 auto;
    }
    .avatar img{
      width: 100%;
      height: 100%;
      object-fit: cover;
      display:block;
    }
    .brandText{
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .brandText strong{ font-size: 16px; letter-spacing: 0.2px; }
    .brandText span{ font-size: 12px; color: var(--muted2); }

    .navWrapper {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav{
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 8px;
      margin: 0;
    }

    .hamburger span {
      width: 24px;
      height: 2px;
      background: var(--text);
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    .hamburger.active span:nth-child(1) {
      transform: rotate(45deg) translate(8px, 8px);
    }

    .hamburger.active span:nth-child(2) {
      opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -7px);
    }

    .pill{
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(2, 132, 199, 0.06);
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 13px;
      transition: transform .12s ease, background .12s ease, border-color .12s ease;
      user-select: none;
    }
    .pill:hover{
      transform: translateY(-1px);
      background: rgba(14,165,166,0.10);
      border-color: rgba(14,165,166,0.28);
      text-decoration: none;
    }
    .pill.active{
      color: var(--activeTabTx);
      background: var(--activeTabBg);
      border-color: var(--activeTabBd);
    }

    .page{ display: none; padding-top: 20px; }
    .page.active{ display: block; }

    .card{
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .card.pad{ padding: 18px; }

    .grid{ display: grid; gap: 16px; }
    @media (min-width: 900px){
      .grid.cols2{ grid-template-columns: 1.1fr 0.9fr; }
      .grid.cols2even{ grid-template-columns: 1fr 1fr; }
    }

    h1{
      margin: 0 0 8px;
      font-size: 30px;
      letter-spacing: -0.4px;
    }
    h2{
      margin: 0 0 10px;
      font-size: 18px;
      letter-spacing: -0.2px;
    }
    h3{
      margin: 0 0 6px;
      font-size: 15px;
      letter-spacing: 0.1px;
      color: var(--text);
    }
    p{ margin: 0 0 12px; color: var(--muted); }
    .muted{ color: var(--muted2); }
    .kicker{
      color: var(--muted2);
      font-size: 13px;
      margin-bottom: 12px;
    }
    .divider{
      height: 1px;
      background: var(--border);
      margin: 14px 0;
    }

    .btnRow{ display:flex; gap:10px; flex-wrap:wrap; margin-top: 10px; }
    .btn{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border-radius: 12px;
      padding: 10px 12px;
      border: 1px solid var(--btnBd);
      background: var(--btnBg);
      color: var(--btnTx);
      font-size: 13px;
      cursor: pointer;
      transition: transform .12s ease, background .12s ease, border-color .12s ease, box-shadow .12s ease;
      box-shadow: 0 6px 14px rgba(15,23,42,0.06);
      white-space: nowrap;
      text-decoration: none;
    }
    .btn:hover{
      transform: translateY(-1px);
      background: rgba(14,165,166,0.16);
      border-color: rgba(14,165,166,0.40);
      text-decoration: none;
    }
    .btn.ghost{
      background: transparent;
      border-color: var(--border);
      color: var(--text);
    }
    .btn.ghost:hover{
      background: rgba(15,23,42,0.04);
      border-color: rgba(15,23,42,0.14);
    }

    .btn.fx{
      background: rgba(99,102,241,0.12);
      border-color: rgba(99,102,241,0.34);
      color: #3730a3;
    }
    .btn.fx:hover{
      background: rgba(99,102,241,0.18);
      border-color: rgba(99,102,241,0.44);
    }

    .btn.rc{
      background: var(--rcBtnBg);
      border-color: var(--rcBtnBd);
      color: var(--rcBtnTx);
    }
    .btn.rc:hover{
      background: rgba(99,102,241,0.18);
      border-color: rgba(99,102,241,0.44);
    }

    /* Alternating "Open Post" button colors — cycle of 4 */
    .btn.op1{ background: var(--opBtn1Bg); border-color: var(--opBtn1Bd); color: var(--opBtn1Tx); }
    .btn.op1:hover{ background: rgba(99,102,241,0.20); border-color: rgba(99,102,241,0.44); text-decoration:none; }
    .btn.op2{ background: var(--opBtn2Bg); border-color: var(--opBtn2Bd); color: var(--opBtn2Tx); }
    .btn.op2:hover{ background: rgba(37,99,235,0.18); border-color: rgba(37,99,235,0.44); text-decoration:none; }
    .btn.op3{ background: var(--opBtn3Bg); border-color: var(--opBtn3Bd); color: var(--opBtn3Tx); }
    .btn.op3:hover{ background: rgba(14,165,166,0.20); border-color: rgba(14,165,166,0.44); text-decoration:none; }
    .btn.op4{ background: var(--opBtn4Bg); border-color: var(--opBtn4Bd); color: var(--opBtn4Tx); }
    .btn.op4:hover{ background: rgba(14,165,166,0.14); border-color: rgba(14,165,166,0.36); text-decoration:none; }

    /* Posts carousel wrapper */
    .postsCarouselWrap{
      position: relative;
    }
    .scrollBtn{
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      width: 38px; height: 38px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.95);
      box-shadow: 0 4px 12px rgba(15,23,42,0.12);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      color: var(--text);
      transition: background .12s, box-shadow .12s, opacity .18s;
      user-select: none;
    }
    .scrollBtn:hover{
      background: rgba(255,255,255,1);
      box-shadow: 0 6px 18px rgba(15,23,42,0.16);
    }
    .scrollBtn.left{ left: -14px; }
    .scrollBtn.right{ right: -14px; }
    .scrollBtn.hidden{ opacity: 0; pointer-events: none; }

    /* Shared footer nav across all pages */
    .pageFooter{
      margin-top: 22px;
      padding-top: 18px;
      color: var(--muted2);
      font-size: 12px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .list{ margin: 0; padding-left: 18px; color: var(--muted); }
    .list li{ margin: 6px 0; }

    .timeline{ display: grid; gap: 12px; margin-top: 10px; }
    .tItem{
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.92);
      padding: 14px;
      box-shadow: 0 8px 18px rgba(15,23,42,0.06);
    }
    .tTop{
      display:flex;
      gap: 10px;
      align-items:flex-start;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .when{
      font-size: 12px;
      color: var(--muted2);
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.9);
    }
    .tMeta{ color: var(--muted2); font-size: 13px; margin-top: 4px; }

    .heroRow{
      display:flex;
      gap: 14px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .heroPic{
      width: 140px; height: 140px;
      border-radius: 28px;
      border: 1px solid var(--border);
      overflow:hidden;
      box-shadow: var(--shadow2);
      background: rgba(14,165,166,0.10);
      flex: 0 0 auto;
    }
    .heroPic img{
      width:100%; height:100%;
      object-fit: cover;
      display:block;
    }

    .stack{ display: grid; gap: 0px; }

    .cardPost{
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.92);
      box-shadow: var(--shadow2);
      overflow: hidden;
      display:flex;
      flex-direction: column;
    }

    .cardMedia{
      height: 190px;
      background:
        radial-gradient(380px 180px at 18% 25%, rgba(14,165,166,0.16), transparent 60%),
        radial-gradient(320px 200px at 84% 30%, rgba(37,99,235,0.14), transparent 65%),
        rgba(255,255,255,0.85);
      border-bottom: 1px solid var(--border);
      overflow:hidden;
    }
    .cardMedia img{
      width:100%;
      height:100%;
      object-fit: cover;
      display:block;
    }
    .cardBody{
      padding: 12px 14px 14px;
      display:flex;
      flex-direction: column;
      gap: 8px;
      flex: 1;
    }
    .cardTitle{
      font-size: 14px;
      color: var(--text);
      line-height: 1.25;
      margin: 0;
      font-weight: 700;
    }
    .cardText{
      font-size: 13px;
      color: var(--muted);
      margin: 0;
      flex: 1;
    }
    .cardFooter{
      margin-top: auto;
      padding-top: 10px;
      display:flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }
    .mini{ font-size: 12px; color: var(--muted2); }

    .chips{
      display:flex;
      flex-wrap:wrap;
      gap: 8px;
      margin-top: 10px;
    }
    .chip{
      font-size: 12px;
      padding: 8px 10px;
      border-radius: 999px;
      border: 1px solid var(--skillBd);
      background: var(--skillBg);
      color: var(--skillTx);
      box-shadow: 0 6px 14px rgba(15,23,42,0.06);
    }

    .sectionHead{
      display:flex;
      align-items:flex-end;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    footer{
      margin-top: 22px;
      padding-top: 18px;
      color: var(--muted2);
      font-size: 12px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }
    :focus-visible{
      outline: 3px solid var(--focus);
      outline-offset: 2px;
      border-radius: 10px;
    }

    .lovePurple{ background: var(--lovePurpleBg) !important; border-color: var(--lovePurpleBd) !important; }
    .loveGreen{ background: var(--loveGreenBg) !important; border-color: var(--loveGreenBd) !important; }
    .loveBlue{ background: var(--loveBlueBg) !important; border-color: var(--loveBlueBd) !important; }

    .whiteSection{ background: #ffffff; box-shadow: var(--shadow); }
    .researchCard{
      background: var(--researchCardBg);
      border-color: var(--researchCardBd);
    }
    .pubCard{
      background: var(--pubCardBg);
      border-color: var(--pubCardBd);
    }

    .contactBoxGreen{
      background: var(--contactGreenBg) !important;
      border-color: var(--contactGreenBd) !important;
    }
    .contactBoxGreen a{
      color: var(--contactGreenTx) !important;
      font-weight: 600;
      text-decoration: none;
    }
    .contactBoxGreen a:hover{ text-decoration: underline; }

    .contactBoxBlue{
      background: var(--contactBlueBg) !important;
      border-color: var(--contactBlueBd) !important;
    }
    .contactBoxBlue a{
      color: var(--contactBlueTx) !important;
      font-weight: 600;
      text-decoration: none;
    }
    .contactBoxBlue a:hover{ text-decoration: underline; }

    /* CV Sidebar Styles */
    .cvContainer {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      position: relative;
    }

    @media (min-width: 1200px) {
      .cvContainer {
        grid-template-columns: 240px 1fr;
      }
    }

    .cvSidebar {
      display: none;
      position: sticky;
      top: 80px;
      height: fit-content;
      padding: 16px;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    @media (min-width: 1200px) {
      .cvSidebar {
        display: block;
      }
    }

    .cvSidebar h3 {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted2);
      margin: 0 0 12px 0;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    .cvSidebarLink {
      display: block;
      padding: 10px 12px;
      margin: 4px 0;
      border-radius: 8px;
      color: var(--muted);
      font-size: 13px;
      transition: background .12s ease, color .12s ease;
      text-decoration: none;
      border-left: 3px solid transparent;
    }

    .cvSidebarLink:hover {
      background: rgba(99, 102, 241, 0.08);
      color: var(--text);
      border-left-color: var(--purple);
      text-decoration: none;
    }

    .cvSidebarLink.active {
      background: rgba(99, 102, 241, 0.12);
      color: var(--purple);
      border-left-color: var(--purple);
      font-weight: 600;
    }

    .cvSidebarLinks {
      display: flex;
      flex-direction: column;
      gap: 0;
      flex: 1;
    }

    .sidebarScrollBtn.top::after {
      content: '↑';
    }

    .sidebarScrollBtn.bottom::after {
      content: '↓';
    }

    .thingsContainer {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      position: relative;
    }

    @media (min-width: 1200px) {
      .thingsContainer {
        grid-template-columns: 240px 1fr;
      }
    }

    .thingsSidebar {
      display: none;
      position: sticky;
      top: 80px;
      height: fit-content;
      padding: 16px;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    @media (min-width: 1200px) {
      .thingsSidebar {
        display: block;
      }
    }

    .thingsSidebar h3 {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted2);
      margin: 0 0 12px 0;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);

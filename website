  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    const routes = ["home","cv","research","posts","things","contact"];
    const pages = [...document.querySelectorAll(".page")];
    const navLinks = [...document.querySelectorAll("[data-route]")];
    const hamburger = document.getElementById("hamburger");
    const nav = document.getElementById("nav");

    function setActiveRoute(route){
      const safe = routes.includes(route) ? route : "home";
      pages.forEach(p => p.classList.toggle("active", p.dataset.page === safe));
      navLinks.forEach(a => a.classList.toggle("active", a.dataset.route === safe));
    }

    function onHashChange(){
      const hash = (location.hash || "#home").replace("#","");
      setActiveRoute(hash);
    }

    // Hamburger menu toggle
    if (hamburger) {
      hamburger.addEventListener("click", () => {
        hamburger.classList.toggle("active");
        nav.classList.toggle("visible");
      });
    }

    // Close menu when clicking on a link (only on mobile)
    if (nav) {
      nav.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", () => {
          // Only close menu on screens under 1000px
          if (window.innerWidth < 1000) {
            hamburger.classList.remove("active");
            nav.classList.remove("visible");
          }
        });
      });
    }

    window.addEventListener("hashchange", onHashChange);
    onHashChange();

    // Fill all footer year spans
    const yr = new Date().getFullYear();
    document.querySelectorAll(".footerYear, #year").forEach(el => el.textContent = yr);

    const toggleBtn = document.getElementById("toggleCaptionsBtn");
    let captionsOn = true;

    function updateCaptionBtn(){
      if (!toggleBtn) return;
      toggleBtn.textContent = captionsOn ? "Mini Summary (on)" : "Mini Summary (off)";
    }
    updateCaptionBtn();

    toggleBtn?.addEventListener("click", () => {
      captionsOn = !captionsOn;
      document.querySelectorAll(".caption").forEach(el => {
        el.style.display = captionsOn ? "" : "none";
      });
      updateCaptionBtn();
    });

    // Scroll buttons for posts carousel
    const scroller = document.getElementById("postsScroller");
    const btnLeft  = document.getElementById("scrollLeft");
    const btnRight = document.getElementById("scrollRight");

    function updateScrollBtns(){
      if (!scroller) return;
      const atStart = scroller.scrollLeft <= 4;
      const atEnd   = scroller.scrollLeft + scroller.clientWidth >= scroller.scrollWidth - 4;
      btnLeft.classList.toggle("hidden", atStart);
      btnRight.classList.toggle("hidden", atEnd);
    }

    if (scroller){
      scroller.addEventListener("scroll", updateScrollBtns, { passive: true });
      updateScrollBtns();

      btnLeft.addEventListener("click", () => {
        scroller.scrollBy({ left: -320, behavior: "smooth" });
      });
      btnRight.addEventListener("click", () => {
        scroller.scrollBy({ left: 320, behavior: "smooth" });
      });
    }

    function scrollToTargetId(targetId){
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const headerHeight = document.querySelector('.topbar')?.offsetHeight || 70;
      const top = el.getBoundingClientRect().top + window.scrollY - headerHeight - 16;
      window.scrollTo({ top, behavior: "smooth" });
      el.animate(
        [
          { boxShadow: "0 0 0 rgba(0,0,0,0)" },
          { boxShadow: "0 0 0 6px rgba(99,102,241,0.18)" },
          { boxShadow: "0 0 0 rgba(0,0,0,0)" }
        ],
        { duration: 900, easing: "ease-out" }
      );
    }

    document.querySelectorAll('a[data-scrolltarget]').forEach(a => {
      a.addEventListener("click", (e) => {
          const route = a.getAttribute("data-route");
        const targetId = a.getAttribute("data-scrolltarget");
        if (!route || !targetId) return;

        location.hash = "#" + route;
        setTimeout(() => {
          requestAnimationFrame(() => scrollToTargetId(targetId));
        }, 0);

        e.preventDefault();
      });
    });

    // CV Sidebar Link Active State and Autoscroll
    const cvSidebarLinks = document.querySelectorAll('.cvSidebarLink');
    
    function updateActiveSidebarLink() {
      const scrollPosition = window.scrollY + 120;
      const sections = ['cv-education', 'cv-experience', 'cv-contrib-awards', 'cv-research-contrib'];
      let activeSection = sections[0];

      for (let section of sections) {
        const element = document.getElementById(section);
        if (element && element.offsetTop <= scrollPosition) {
          activeSection = section;
        }
      }

      cvSidebarLinks.forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('data-section') === activeSection) {
          link.classList.add('active');
        }
      });
    }

    cvSidebarLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const sectionId = link.getAttribute('data-section');
        const element = document.getElementById(sectionId);
        if (element) {
          const headerHeight = document.querySelector('.topbar')?.offsetHeight || 80;
          const top = element.offsetTop - headerHeight - 20;
          window.scrollTo({ top, behavior: 'smooth' });
          setTimeout(() => updateActiveSidebarLink(), 100);
        }
      });
    });

    window.addEventListener('scroll', updateActiveSidebarLink, { passive: true });
    updateActiveSidebarLink();

    // Check for CV page and ensure sidebar updates
    if (document.querySelector('#page-cv')) {
      setInterval(updateActiveSidebarLink, 500);
    }

    // Things I Love Sidebar Link Active State and Autoscroll
    const thingsSidebarLinks = document.querySelectorAll('.thingsSidebarLink');
    
    function updateActiveThingsSidebarLink() {
      const scrollPosition = window.scrollY + 120;
      const pageHeight = document.body.scrollHeight;
      const windowHeight = window.innerHeight;
      const sections = ['things-bucketlist', 'things-food', 'things-travel', 'things-books', 'things-movies'];
      let activeSection = sections[0];

      // Check if at bottom of page - highlight Movies
      if (scrollPosition + windowHeight >= pageHeight - 100) {
        activeSection = 'things-movies';
      } else {
        for (let section of sections) {
          const element = document.getElementById(section);
          if (element && element.offsetTop <= scrollPosition) {
            activeSection = section;
          }
        }
      }

      thingsSidebarLinks.forEach(link => {
        link.classList.remove('active');
        const linkSection = link.getAttribute('data-section');
        if (linkSection === activeSection) {
          link.classList.add('active');
        }
      });
    }

    thingsSidebarLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const sectionId = link.getAttribute('data-section');
        
        const element = document.getElementById(sectionId);
        if (element) {
          const headerHeight = document.querySelector('.topbar')?.offsetHeight || 80;
          const top = element.offsetTop - headerHeight - 20;
          window.scrollTo({ top, behavior: 'smooth' });
        }
        setTimeout(() => updateActiveThingsSidebarLink(), 100);
      });
    });

    window.addEventListener('scroll', updateActiveThingsSidebarLink, { passive: true });
    updateActiveThingsSidebarLink();

    // Check for Things page and ensure sidebar updates
    if (document.querySelector('#page-things')) {
      setInterval(updateActiveThingsSidebarLink, 500);
    }

    // Scroll to top and bottom buttons for CV sidebar
    const cvScrollTop = document.getElementById('cvScrollTop');
    const cvScrollBottom = document.getElementById('cvScrollBottom');
    
    if (cvScrollTop) {
      cvScrollTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    if (cvScrollBottom) {
      cvScrollBottom.addEventListener('click', () => {
        window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
      });
    }

    // Scroll to top and bottom buttons for Things I Love sidebar
    const thingsScrollTop = document.getElementById('thingsScrollTop');
    const thingsScrollBottom = document.getElementById('thingsScrollBottom');
    
    if (thingsScrollTop) {
      thingsScrollTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    if (thingsScrollBottom) {
      thingsScrollBottom.addEventListener('click', () => {
        window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
      });
    }
  </script>
